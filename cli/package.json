    "nextjs",
    "html",
    "markdown",
    "pdf",
    "html-to-link",
    "html-to-url",
    "publish-html-online",
    "host-html-file-online",
    "html-file-hosting",
    "upload-html-file-to-website",
    "markdown-to-website",
    "ai-generated-html",
    "chatgpt-html",
    "claude-html-preview",
    "claude-html-artifact",
    "claude-artifacts",
    "claude-artifact-url",
    "netlify-drop",
    "netlify-drop-alternative",
    "hostmyclaudehtml",
    "htmlpub",
    "html-pub",
    "claude-code",
    "codex",
    "codex-website-preview",
    "cursor",
    "ai-agent",
    "static-preview",
    "vercel",
    "cli",
    "mcp"
  ],
  "homepage": "https://previewship.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/blockdancez/PreviewShip"
  },
  "license": "MIT",
  "author": "PreviewShip",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "previewship": "./bin/previewship.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "archiver": "^7.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
