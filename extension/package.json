{
  "name": "previewship",
  "displayName": "PreviewShip",
  "description": "Upload HTML, Markdown, PDF, or static build output from VS Code/Cursor and get a fixed share link—no Git, domain, or server setup.",
  "version": "1.0.12",
  "publisher": "previewship",
  "icon": "resources/icon.png",
  "license": "MIT",
  "homepage": "https://previewship.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/blockdancez/PreviewShip"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "deploy",
    "preview",
    "share",
    "static",
    "hosting",
    "static-preview",
    "frontend-build",
    "react",
    "vue",
    "vite",
    "nextjs",
    "html",
    "markdown",
    "pdf",
    "html-to-link",
    "html-to-url",
    "publish-html-online",
    "host-html-file-online",
    "html-file-hosting",
    "upload-html-file-to-website",
    "markdown-to-website",
    "ai-generated-html",
    "chatgpt-html",
    "claude-html-preview",
    "claude-html-artifact",
    "claude-artifact-url",
    "netlify-drop",
    "netlify-drop-alternative",
    "hostmyclaudehtml",
    "cursor",
    "codex",
    "claude",
    "mcp"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "previewship.setApiKey",
        "title": "PreviewShip: Set API Key"
      },
      {
        "command": "previewship.deploy",
        "title": "PreviewShip: Deploy Workspace, HTML, Markdown, or PDF File"
      },
      {
        "command": "previewship.deployActiveHtml",
        "title": "PreviewShip: Deploy Active HTML, Markdown, or PDF File"
      },
      {
        "command": "previewship.showUsage",
        "title": "PreviewShip: Show Usage"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "previewship.deployActiveHtml",
          "when": "resourceScheme == file && resourceExtname =~ /\\.(html?|md|markdown|pdf)$/i",
          "group": "navigation@20"
        }
      ]
    },
    "configuration": {
      "title": "PreviewShip",
      "properties": {
        "previewship.serverUrl": {
          "type": "string",
          "default": "https://api.previewship.com",
          "description": "PreviewShip API server URL"
        },
        "previewship.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules/**",
            ".git/**",
            ".DS_Store",
            "Thumbs.db",
            ".env",
            ".env.*",
            "*.log",
            ".vscode/**",
            ".idea/**",
            "__pycache__/**",
            "*.pyc",
            ".next/**",
            ".nuxt/**",
            "coverage/**",
            ".cache/**"
          ],
          "description": "Glob patterns to exclude when creating the zip archive"
        },
        "previewship.billingUrl": {
          "type": "string",
          "default": "https://previewship.com/billing",
          "description": "Billing page URL (opened when quota is exceeded)"
        },
        "previewship.pollIntervalMs": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "maximum": 15000,
          "description": "Polling interval for deployment status (milliseconds)"
        },
        "previewship.pollTimeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 30000,
          "maximum": 600000,
          "description": "Maximum polling timeout for deployment status (milliseconds), default 5 minutes"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --minify && vsce package --allow-missing-repository",
    "publish:vsx": "npx ovsx publish",
    "publish:vsce": "vsce publish"
  },
  "dependencies": {
    "archiver": "^7.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "ovsx": "^0.9.0",
    "typescript": "^5.5.0"
  }
}
