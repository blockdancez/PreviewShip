!README.md
!README-zh.md
!CONTEXT.md
!.gitignore

# 在跟踪目录内排除构建产物和依赖
node_modules/
dist/
out/
__pycache__/
*.pyc
*.vsix
*.tgz
.DS_Store
*.log
