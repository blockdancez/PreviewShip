    "nextjs",
    "html",
    "markdown",
    "html-to-link",
    "html-to-url",
    "markdown-to-website",
    "ai-generated-html",
    "chatgpt-html",
    "claude-artifacts",
    "codex",
    "codex-website-preview",
    "static-preview",
    "claude-code",
    "cursor",
    "windsurf",
    "ai-agent"
  ],
  "homepage": "https://previewship.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/blockdancez/PreviewShip"
  },
  "license": "MIT",
  "author": "PreviewShip",
  "type": "module",
  "main": "./dist/index.js",
